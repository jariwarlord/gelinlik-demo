---
import SocialIcon from './SocialIcon.astro';

interface Props {
  variant?: 'home' | 'contact' | 'minimal';
}

const { variant = 'home' } = Astro.props;

const config = {
  home: {
    brand: 'Seçil Gelinlik',
    location: 'Keşan',
    slogan: 'Hayallerinizi süsleyen gelinlikler tasarlıyoruz.',
    email: 'secil.gelinlik@gmail.com',
    whatsappNumber: '905441786244',
    copyright: '© 2025 Seçil Gelinlik | Keşan',
  },
  contact: {
    brand: 'Seçil Gelinlik',
    location: null,
    slogan: '10 yıldır hayallerinizi süsleyen gelinlikler tasarlıyoruz.',
    email: 'info@gelinlik.com',
    whatsappNumber: '905441726244',
    copyright: '© 2025 Seçil Gelinlik',
  },
};

const cfg = variant === 'contact' ? config.contact : config.home;
---

{
  variant === 'minimal' ? (
    <footer class="border-t border-border/50 mt-24">
      <div class="max-w-content mx-auto px-6 py-8">
        <p class="text-fg-subtle text-xs tracking-wide text-center">
          © 2025 Seçil Gelinlik | Keşan
        </p>
      </div>
    </footer>
  ) : (
    <footer class="mt-24 bg-surface-2 border-t border-border/50">
      <div class="max-w-content mx-auto px-6 py-16">
        <div class="grid md:grid-cols-3 gap-12 text-center md:text-left">
          <div class="space-y-4">
            <h3 class="font-script text-3xl text-brand leading-none">
              {cfg.brand}
              {cfg.location && (
                <span class="text-fg-muted font-body text-base"> | {cfg.location}</span>
              )}
            </h3>
            <p class="text-fg-muted text-sm leading-relaxed max-w-xs mx-auto md:mx-0">
              {cfg.slogan}
            </p>
          </div>

          <div class="space-y-4">
            <h4 class="text-xs tracking-[0.2em] uppercase text-fg-subtle font-medium">İletişim</h4>
            <div class="space-y-2">
              <a
                href={`mailto:${cfg.email}`}
                class="block text-fg hover:text-brand transition-colors text-sm"
              >
                {cfg.email}
              </a>
              <a
                href="tel:+905441786244"
                class="block text-fg hover:text-brand transition-colors text-sm"
              >
                +90 544 178 62 44
              </a>
            </div>
          </div>

          <div class="space-y-4">
            <h4 class="text-xs tracking-[0.2em] uppercase text-fg-subtle font-medium">
              Bizi Takip Edin
            </h4>
            <div class="flex items-center justify-center md:justify-start gap-3">
              <a
                href="https://www.instagram.com/secil_gelinlik_kesan/"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
                class="w-11 h-11 rounded-full bg-gradient-to-br from-[#feda75] via-[#fa7e1e] via-50% to-[#d62976] text-white hover:opacity-90 transition-opacity flex items-center justify-center"
              >
                <SocialIcon name="instagram" size={18} />
              </a>
              <a
                href="https://www.facebook.com/secilgelinlikkesan/"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Facebook"
                class="w-11 h-11 rounded-full bg-[#1877F2] hover:bg-[#0d65d9] text-white transition-colors flex items-center justify-center"
              >
                <SocialIcon name="facebook" size={18} />
              </a>
              <a
                href={`https://wa.me/${cfg.whatsappNumber}?text=Merhaba%20randevu%20almak%20istiyorum`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="WhatsApp"
                class="w-11 h-11 rounded-full bg-whatsapp hover:bg-whatsapp-hover text-white transition-colors flex items-center justify-center"
              >
                <SocialIcon name="whatsapp" size={18} />
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="border-t border-border/50">
        <div class="max-w-content mx-auto px-6 py-5">
          <p class="text-fg-subtle text-xs tracking-wide text-center">{cfg.copyright}</p>
        </div>
      </div>
    </footer>
  )
}
