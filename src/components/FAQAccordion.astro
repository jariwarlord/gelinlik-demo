---
import type { CityFaq } from '../data/cities';

interface Props {
  faq: CityFaq[];
  title?: string;
  eyebrow?: string;
}

const { faq, title = 'Sık Sorulan Sorular', eyebrow = 'SSS' } = Astro.props;
---

<section class="py-24 md:py-32 bg-white border-t border-fg/5">
  <div class="max-w-3xl mx-auto px-6">
    <div class="text-center mb-14 md:mb-16">
      <p class="font-script text-2xl text-brand mb-3">{eyebrow}</p>
      <h2 class="font-heading text-4xl md:text-5xl text-fg leading-tight">{title}</h2>
    </div>

    <div class="space-y-3">
      {
        faq.map((item) => (
          <details class="group border border-fg/10 bg-surface/50 transition-colors hover:border-brand/40">
            <summary class="flex items-start justify-between gap-6 px-6 py-5 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
              <span class="font-heading text-lg md:text-xl text-fg leading-snug">{item.q}</span>
              <span
                aria-hidden="true"
                class="flex-shrink-0 mt-1 w-6 h-6 rounded-full border border-brand/40 text-brand flex items-center justify-center transition-transform duration-300 group-open:rotate-45"
              >
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                  <path
                    d="M6 1.5V10.5M1.5 6H10.5"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                  />
                </svg>
              </span>
            </summary>
            <div class="px-6 pb-6 pt-0">
              <p class="text-fg-muted leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
