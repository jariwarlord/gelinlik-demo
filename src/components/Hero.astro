---
const slides = [
  '/images/1.jpg',
  '/images/2.jpg',
  '/images/3.jpg',
  '/images/4.jpg',
  '/images/5.jpg',
];
---

<section class="hero-carousel relative min-h-[600px] md:min-h-screen overflow-hidden bg-ink">
  <div class="absolute inset-0">
    {
      slides.map((src, i) => (
        <div
          class="hero-slide absolute inset-0 transition-opacity duration-[1200ms] ease-out"
          data-index={i}
          style={i === 0 ? 'opacity:1' : 'opacity:0'}
        >
          <img
            src={src}
            alt=""
            loading={i === 0 ? 'eager' : 'lazy'}
            class="hero-slide-img w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/20 to-black/70" />
        </div>
      ))
    }
  </div>

  <div class="relative h-full min-h-[600px] md:min-h-screen flex flex-col items-center justify-center text-center px-6 py-24">
    <p class="font-script text-2xl md:text-3xl text-white/80 mb-3">Hayalleriniz</p>
    <h1 class="font-heading text-5xl md:text-7xl lg:text-8xl text-white leading-[1.05] max-w-4xl mb-6">
      Gelinliğin Hikâyesi
    </h1>
    <p class="text-base md:text-lg text-white/85 max-w-xl mb-10 leading-relaxed">
      Özel günleriniz için zarafet ve şıklığı bir araya getiriyoruz.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a
        href="/gallery"
        class="px-8 py-4 bg-brand hover:bg-brand-hover text-white text-sm font-medium tracking-[0.15em] uppercase transition-colors"
      >
        Koleksiyonu Keşfet
      </a>
      <a
        href="/contact"
        class="px-8 py-4 border border-white/50 hover:bg-white/10 text-white text-sm font-medium tracking-[0.15em] uppercase transition-colors"
      >
        Randevu Al
      </a>
    </div>
  </div>

  <button
    class="hero-arrow hero-arrow-prev"
    data-direction="prev"
    aria-label="Önceki slayt"
    type="button"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M15 18L9 12L15 6"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
      ></path>
    </svg>
  </button>
  <button
    class="hero-arrow hero-arrow-next"
    data-direction="next"
    aria-label="Sonraki slayt"
    type="button"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M9 6L15 12L9 18"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
      ></path>
    </svg>
  </button>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex items-center gap-2 z-10">
    {
      slides.map((_, i) => (
        <button
          class="hero-dot h-1 bg-white/40 rounded-full transition-all duration-300"
          data-index={i}
          aria-label={`${i + 1}. slayt`}
          style={i === 0 ? 'width:32px;background:white' : 'width:16px'}
        />
      ))
    }
  </div>
</section>

<style>
  .hero-slide-img {
    animation: kenburns 10s ease-out infinite alternate;
    will-change: transform;
  }
  @keyframes kenburns {
    from {
      transform: scale(1) translate(0, 0);
    }
    to {
      transform: scale(1.08) translate(-1%, -1%);
    }
  }
  .hero-dot.is-active {
    width: 32px !important;
    background: white !important;
  }
  .hero-dot:not(.is-active) {
    width: 16px !important;
    background: rgba(255, 255, 255, 0.4) !important;
  }

  .hero-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.35);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    cursor: pointer;
    transition:
      background 0.25s ease,
      border-color 0.25s ease,
      transform 0.25s ease,
      opacity 0.25s ease;
    opacity: 0.85;
  }
  .hero-arrow:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.65);
    opacity: 1;
  }
  .hero-arrow:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }
  .hero-arrow-prev {
    left: 16px;
  }
  .hero-arrow-next {
    right: 16px;
  }
  @media (min-width: 768px) {
    .hero-arrow {
      width: 56px;
      height: 56px;
    }
    .hero-arrow-prev {
      left: 32px;
    }
    .hero-arrow-next {
      right: 32px;
    }
    .hero-arrow-prev:hover {
      transform: translateY(-50%) translateX(-2px);
    }
    .hero-arrow-next:hover {
      transform: translateY(-50%) translateX(2px);
    }
  }
</style>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.hero-slide');
  const dots = document.querySelectorAll<HTMLElement>('.hero-dot');
  const arrows = document.querySelectorAll<HTMLElement>('.hero-arrow');
  let current = 0;
  let timer: ReturnType<typeof setInterval> | null = null;

  function setActive(index: number) {
    slides.forEach((slide, i) => {
      slide.style.opacity = i === index ? '1' : '0';
    });
    dots.forEach((dot, i) => {
      dot.classList.toggle('is-active', i === index);
    });
    current = index;
  }

  function next() {
    setActive((current + 1) % slides.length);
  }

  function prev() {
    setActive((current - 1 + slides.length) % slides.length);
  }

  function start() {
    timer = setInterval(next, 5500);
  }

  function reset() {
    if (timer) clearInterval(timer);
    start();
  }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      setActive(i);
      reset();
    });
  });

  arrows.forEach((arrow) => {
    arrow.addEventListener('click', () => {
      const dir = arrow.dataset.direction;
      if (dir === 'prev') prev();
      else next();
      reset();
    });
  });

  if (slides.length > 0) {
    setActive(0);
    start();
  }
</script>
