---
interface CollectionItem {
  src: string;
  alt: string;
  title: string;
}

interface Props {
  title?: string;
  items: CollectionItem[];
  lightbox?: boolean;
}

const { title, items, lightbox = false } = Astro.props;
---

<section class="py-16 md:py-24 bg-surface">
  <div class="max-w-content mx-auto px-6">
    {
      title && (
        <div class="text-center mb-12 md:mb-16">
          <h2 class="font-heading text-3xl md:text-4xl text-fg">{title}</h2>
        </div>
      )
    }

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6 lg:gap-8">
      {
        items.map((item) =>
          lightbox ? (
            <article class="group">
              <a
                href={item.src}
                class="lightbox block relative aspect-[3/4] overflow-hidden bg-white"
              >
                <img
                  src={item.src}
                  alt={item.alt}
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-[800ms] ease-out group-hover:scale-[1.04]"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
              </a>
              <h3 class="mt-3 md:mt-4 text-sm text-fg-muted tracking-wide">{item.title}</h3>
            </article>
          ) : (
            <article class="group">
              <div class="block relative aspect-[3/4] overflow-hidden bg-white">
                <img
                  src={item.src}
                  alt={item.alt}
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-[800ms] ease-out group-hover:scale-[1.04]"
                />
              </div>
              <h3 class="mt-3 md:mt-4 text-sm text-fg-muted tracking-wide">{item.title}</h3>
            </article>
          )
        )
      }
    </div>
  </div>
</section>
