---
interface Props {
  activeNav?: 'home' | 'gallery' | 'contact';
  subtitle?: string;
}

const { activeNav, subtitle } = Astro.props;
---

<header class="site-header">
  <div class="container">
    <a href="/" class="logo">
      <span class="logo-text">Seçil Gelinlik</span>
    </a>
    <nav class="nav">
      <ul>
        <li>
          <a href="/" class={activeNav === 'home' ? 'active' : ''}>Anasayfa</a>
        </li>
        <li>
          <a href="/gallery" class={activeNav === 'gallery' ? 'active' : ''}>Koleksiyon</a>
        </li>
        <li>
          <a href="/contact" class={activeNav === 'contact' ? 'active' : ''}>Randevu</a>
        </li>
      </ul>
    </nav>
    <div class="hamburger">
      <span></span><span></span><span></span>
    </div>
  </div>
  {
    subtitle && (
      <p style="font-family: 'Playfair Display', serif; font-size:1.2rem; color:#ff6b81; margin-bottom:20px; font-weight:600; text-align:center;">
        {subtitle}
      </p>
    )
  }
</header>

<script>
  const hamburger = document.querySelector('.hamburger');
  const nav = document.querySelector('.nav');
  if (hamburger && nav) {
    hamburger.addEventListener('click', () => {
      nav.classList.toggle('open');
      hamburger.classList.toggle('active');
    });
  }
</script>
