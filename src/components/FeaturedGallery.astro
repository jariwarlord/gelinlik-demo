---
interface FeaturedItem {
  src: string;
  alt: string;
  title: string;
  desc: string;
}

interface Props {
  items: FeaturedItem[];
}

const { items } = Astro.props;
---

<section class="py-24 md:py-32 bg-white">
  <div class="max-w-content mx-auto px-6">
    <div class="text-center mb-16 md:mb-20">
      <p class="font-script text-2xl text-brand mb-3">Koleksiyon</p>
      <h2 class="font-heading text-4xl md:text-5xl text-fg leading-tight">
        Öne Çıkan Modeller
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {
        items.map((item) => (
          <article class="group">
            <a
              href={item.src}
              class="lightbox block relative aspect-[3/4] overflow-hidden bg-surface"
            >
              <img
                src={item.src}
                alt={item.alt}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-[800ms] ease-out group-hover:scale-[1.04]"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
              <div class="absolute bottom-0 left-0 right-0 p-6 text-white translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
                <h3 class="font-heading text-2xl mb-1.5">{item.title}</h3>
                <p class="text-sm text-white/80">{item.desc}</p>
              </div>
            </a>
          </article>
        ))
      }
    </div>

    <div class="mt-16 md:mt-20 text-center">
      <a
        href="/gallery"
        class="inline-flex items-center gap-3 group text-fg hover:text-brand transition-colors"
      >
        <span class="text-xs font-medium tracking-[0.2em] uppercase">Tüm Koleksiyon</span>
        <span class="h-px w-10 bg-current transition-all duration-300 group-hover:w-16"></span>
      </a>
    </div>
  </div>
</section>
