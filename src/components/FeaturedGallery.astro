---
interface FeaturedItem {
  src: string;
  alt: string;
  title: string;
  desc: string;
}

interface Props {
  items: FeaturedItem[];
}

const { items } = Astro.props;
---

<section class="featured">
  <h2>Öne Çıkan Gelinlikler</h2>
  <div class="gallery">
    {
      items.map((item) => (
        <div class="item">
          <a href={item.src} class="lightbox">
            <img src={item.src} alt={item.alt} />
          </a>
          <div class="overlay">
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </div>
        </div>
      ))
    }
  </div>
  <a href="/gallery" class="btn">Tüm Koleksiyon</a>
</section>
