---
import type { City } from '../data/cities';

interface Props {
  cities: City[];
  title?: string;
  subtitle?: string;
  eyebrow?: string;
  showHubLink?: boolean;
  excludeSlug?: string;
}

const {
  cities,
  title = "Trakya'nın Tüm Şehirleri",
  subtitle,
  eyebrow = 'Bölge',
  showHubLink = false,
  excludeSlug,
} = Astro.props;

const visible = excludeSlug ? cities.filter((c) => c.slug !== excludeSlug) : cities;
---

<section class="py-24 md:py-32 bg-white border-t border-fg/5">
  <div class="max-w-content mx-auto px-6">
    <div class="text-center mb-14 md:mb-20 max-w-2xl mx-auto">
      <p class="font-script text-2xl text-brand mb-3">{eyebrow}</p>
      <h2 class="font-heading text-4xl md:text-5xl text-fg leading-tight mb-5">{title}</h2>
      {subtitle && <p class="text-fg-muted text-base md:text-lg leading-relaxed">{subtitle}</p>}
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {
        visible.map((city) => (
          <a
            href={`/${city.slug}`}
            class="group block bg-surface hover:bg-surface-2 border border-fg/5 hover:border-brand/40 transition-all p-8"
          >
            <p class="text-xs tracking-[0.2em] uppercase text-fg-subtle font-medium mb-3">
              {city.region}
            </p>
            <h3 class="font-heading text-2xl md:text-3xl text-fg mb-3 group-hover:text-brand transition-colors">
              {city.name} Gelinlik
            </h3>
            <p class="text-fg-muted text-sm mb-5 leading-relaxed">{city.distanceFromKesan}</p>
            <span class="inline-flex items-center gap-3 text-fg group-hover:text-brand transition-colors">
              <span class="text-xs font-medium tracking-[0.2em] uppercase">İncele</span>
              <span class="h-px w-10 bg-current transition-all duration-300 group-hover:w-16" />
            </span>
          </a>
        ))
      }
    </div>

    {
      showHubLink && (
        <div class="text-center mt-14">
          <a
            href="/trakya-gelinlik"
            class="inline-flex items-center gap-3 text-fg hover:text-brand transition-colors group"
          >
            <span class="text-sm font-medium tracking-[0.2em] uppercase">
              Trakya Gelinlik Atölyesi
            </span>
            <span class="h-px w-12 bg-current transition-all duration-300 group-hover:w-20" />
          </a>
        </div>
      )
    }
  </div>
</section>
