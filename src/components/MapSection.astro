---
import { business } from '../data/business';
---

<section class="py-24 md:py-32 bg-surface">
  <div class="max-w-content mx-auto px-6">
    <div class="text-center mb-16 md:mb-20">
      <p class="font-script text-2xl text-brand mb-3">Konum</p>
      <h2 class="font-heading text-4xl md:text-5xl text-fg leading-tight">Bizi Bulun</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-5 gap-6 md:gap-8 items-stretch">
      <div class="md:col-span-3 aspect-[4/3] md:aspect-auto overflow-hidden bg-white">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3046.7776142228616!2d26.6317242!3d40.8542772!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14b3c78e8bdde787%3A0xa3cd57e128b5e62b!2sSe%C3%A7il%20Gelinlik%20Ke%C5%9Fan!5e0!3m2!1str!2str!4v1694377000000!5m2!1str!2str"
          width="100%"
          height="100%"
          style="border:0; display:block; min-height: 420px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`${business.name} ${business.address.locality} Konum`}></iframe>
      </div>

      <div class="md:col-span-2 bg-white p-8 md:p-12 flex flex-col justify-center gap-10">
        <div>
          <p class="text-xs tracking-[0.2em] uppercase text-fg-subtle font-medium mb-3">Adres</p>
          <p class="text-fg leading-relaxed">{business.address.full}</p>
          <p class="text-fg-muted text-sm mt-1">Trakya, Türkiye</p>
        </div>

        <div>
          <p class="text-xs tracking-[0.2em] uppercase text-fg-subtle font-medium mb-3">İletişim</p>
          <a
            href={`tel:${business.phone}`}
            class="block text-fg hover:text-brand transition-colors"
          >
            {business.phoneDisplay}
          </a>
          <a
            href={`mailto:${business.email}`}
            class="block text-fg hover:text-brand transition-colors mt-1"
          >
            {business.email}
          </a>
        </div>

        <div>
          <p class="text-xs tracking-[0.2em] uppercase text-fg-subtle font-medium mb-3">
            Çalışma Saatleri
          </p>
          <p class="text-fg">Pazartesi — Cumartesi</p>
          <p class="text-fg-muted text-sm mt-1">
            {business.openingHours.opens} — {business.openingHours.closes}
          </p>
        </div>

        <a
          href="/contact"
          class="inline-flex items-center gap-3 group text-fg hover:text-brand transition-colors mt-2"
        >
          <span class="text-xs font-medium tracking-[0.2em] uppercase">Randevu Al</span>
          <span class="h-px w-10 bg-current transition-all duration-300 group-hover:w-16"></span>
        </a>
      </div>
    </div>
  </div>
</section>
