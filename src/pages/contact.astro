---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroContact from '../components/HeroContact.astro';
import WhatsappForm from '../components/WhatsappForm.astro';
import StreetView from '../components/StreetView.astro';
---

<BaseLayout
  title="Randevu / İletişim | Secil Gelinlik"
  activeNav="contact"
  footerVariant="contact"
>
  <HeroContact
    eyebrow="İletişim"
    title="Randevu Alın"
    subtitle="Hayalinizdeki gelinliği birlikte tasarlayalım. Birkaç bilgiyle randevu talebinizi WhatsApp üzerinden iletelim."
  >
    <WhatsappForm whatsappNumber="905441726244" />
  </HeroContact>
  <StreetView />
</BaseLayout>
