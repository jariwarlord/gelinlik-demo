---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroContact from '../components/HeroContact.astro';
import WhatsappForm from '../components/WhatsappForm.astro';
import StreetView from '../components/StreetView.astro';
---

<BaseLayout
  title="Randevu / İletişim | Seçil Gelinlik — Keşan Atölyesi"
  description="Seçil Gelinlik atölyesinden ücretsiz deneme randevusu alın. WhatsApp, telefon ve form üzerinden hızlı iletişim. Trakya'nın tüm şehirlerinden ulaşılabilir."
  keywords="seçil gelinlik iletişim, gelinlik randevusu, keşan gelinlik atölye iletişim"
  ogTitle="Randevu / İletişim | Seçil Gelinlik"
  ogDescription="Hayalinizdeki gelinliği birlikte tasarlayalım. WhatsApp veya form ile randevu."
  activeNav="contact"
  footerVariant="contact"
>
  <HeroContact
    eyebrow="İletişim"
    title="Randevu Alın"
    subtitle="Hayalinizdeki gelinliği birlikte tasarlayalım. Birkaç bilgiyle randevu talebinizi WhatsApp üzerinden iletelim."
  >
    <WhatsappForm />
  </HeroContact>
  <StreetView />
</BaseLayout>
