---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCityBySlug } from '../../data/cities';
import {
  articleSchema,
  breadcrumbSchema,
} from '../../lib/schema';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (d: Date) =>
  d.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' });

const relatedCity = post.data.relatedCity ? getCityBySlug(post.data.relatedCity) : undefined;

const url = `/blog/${post.id}`;

const jsonLdArray = [
  articleSchema({
    title: post.data.title,
    description: post.data.description,
    url,
    image: post.data.heroImage,
    publishDate: post.data.publishDate,
    modifiedDate: post.data.modifiedDate,
  }),
  breadcrumbSchema([
    { name: 'Anasayfa', path: '/' },
    { name: 'Blog', path: '/blog' },
    { name: post.data.title, path: url },
  ]),
];
---

<BaseLayout
  title={`${post.data.title} | Seçil Gelinlik Blog`}
  description={post.data.description}
  keywords={post.data.keywords.join(', ')}
  ogTitle={post.data.title}
  ogDescription={post.data.description}
  ogImage={post.data.heroImage}
  ogType="article"
  jsonLdArray={jsonLdArray}
  activeNav="gallery"
>
  <article class="bg-white">
    <header class="py-20 md:py-28 border-b border-fg/5">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="text-xs tracking-[0.2em] uppercase text-fg-subtle font-medium mb-5">
          {formatDate(post.data.publishDate)}
        </p>
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl text-fg leading-tight mb-6">
          {post.data.title}
        </h1>
        <p class="text-fg-muted text-lg leading-relaxed">{post.data.description}</p>
      </div>
    </header>

    {
      post.data.heroImage && (
        <div class="max-w-4xl mx-auto px-6 mt-12">
          <div class="aspect-[16/9] overflow-hidden">
            <img
              src={post.data.heroImage}
              alt={post.data.title}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      )
    }

    <div class="prose-article max-w-3xl mx-auto px-6 py-16 md:py-24">
      <Content />
    </div>

    {
      relatedCity && (
        <aside class="bg-soft/30 border-t border-fg/5 py-16">
          <div class="max-w-3xl mx-auto px-6 text-center">
            <p class="font-script text-2xl text-brand mb-3">İlgili</p>
            <h2 class="font-heading text-3xl md:text-4xl text-fg leading-tight mb-4">
              {relatedCity.name} için Atölyemiz
            </h2>
            <p class="text-fg-muted leading-relaxed mb-6">{relatedCity.distanceFromKesan}</p>
            <a
              href={`/${relatedCity.slug}`}
              class="inline-flex items-center gap-3 text-fg hover:text-brand transition-colors group"
            >
              <span class="text-sm font-medium tracking-[0.2em] uppercase">
                {relatedCity.name} Gelinlik Sayfası
              </span>
              <span class="h-px w-12 bg-current transition-all duration-300 group-hover:w-20" />
            </a>
          </div>
        </aside>
      )
    }

    <div class="max-w-3xl mx-auto px-6 py-12 text-center">
      <a
        href="/blog"
        class="inline-flex items-center gap-3 text-fg hover:text-brand transition-colors group"
      >
        <span class="h-px w-10 bg-current transition-all duration-300 group-hover:w-16"></span>
        <span class="text-xs font-medium tracking-[0.2em] uppercase">Tüm Yazılara Dön</span>
      </a>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose-article p {
    color: var(--color-fg);
    line-height: 1.8;
    font-size: 1.0625rem;
    margin-bottom: 1.5rem;
  }
  .prose-article h2 {
    font-family: var(--font-heading), serif;
    font-size: 1.875rem;
    color: var(--color-fg);
    margin-top: 3rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .prose-article h3 {
    font-family: var(--font-heading), serif;
    font-size: 1.375rem;
    color: var(--color-fg);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }
  .prose-article ul,
  .prose-article ol {
    margin: 1rem 0 1.5rem 1.25rem;
    color: var(--color-fg);
    line-height: 1.7;
  }
  .prose-article ul li {
    list-style: disc;
    margin-bottom: 0.4rem;
  }
  .prose-article ol li {
    list-style: decimal;
    margin-bottom: 0.4rem;
  }
  .prose-article a {
    color: var(--color-brand);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: opacity 0.2s ease;
  }
  .prose-article a:hover {
    opacity: 0.7;
  }
  .prose-article strong {
    color: var(--color-fg);
    font-weight: 700;
  }
  .prose-article table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0 2rem;
    font-size: 0.9375rem;
  }
  .prose-article th,
  .prose-article td {
    border: 1px solid rgba(0, 0, 0, 0.08);
    padding: 0.75rem 1rem;
    text-align: left;
  }
  .prose-article th {
    background: var(--color-surface);
    font-weight: 600;
    font-family: var(--font-heading), serif;
  }
  .prose-article hr {
    border: 0;
    height: 1px;
    background: rgba(0, 0, 0, 0.08);
    margin: 2rem 0;
  }
</style>
